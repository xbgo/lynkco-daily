# refreshToken 相当于长期登录凭证，泄露后请立即改密码并重新获取。
LYNKCO_REFRESH_TOKEN=
# 必填。保持和当前 App 登录设备一致，减少被踢下线概率。
LYNKCO_DEVICE_ID=
LYNKCO_DEVICE_TYPE=IOS
# 可选。留空时分享接口默认使用 4.2.3。
LYNKCO_APP_VERSION=4.1.4
LYNKCO_LATEST_ARTICLE=1
# 0 速度最快：直接用信息流第一篇；填 1/3/5 会额外拉详情校验发布时间。
LYNKCO_LATEST_ARTICLE_LIMIT=0
# 签到完成后等待再执行分享，单位秒。
LYNKCO_SHARE_DELAY_SECONDS=60
# 图形界面安装定时任务时使用。
LYNKCO_SCHEDULE_TIME=10:00
# 可选。填写后推送优先使用该名称；留空则使用接口返回的账户名。
LYNKCO_ACCOUNT_NAME=
LYNKCO_FETCH_ACCOUNT_NAME=1

# 自动化通知。至少填写一个通知渠道。
LYNKCO_NOTIFY=0
LYNKCO_NOTIFY_ON_SUCCESS=1
LYNKCO_NOTIFY_TITLE=领克每日任务
LYNKCO_HITOKOTO=1
LYNKCO_HITOKOTO_URL=https://v1.hitokoto.cn/?encode=json&charset=utf-8
LYNKCO_HITOKOTO_TIMEOUT=2
LYNKCO_HTTP_TIMEOUT=15
LYNKCO_HTTP_RETRIES=3
# PushPlus：只填 token，不填完整 URL。
LYNKCO_PUSHPLUS_TOKEN=
# Server 酱 Turbo：只填 SendKey。
LYNKCO_SERVERCHAN_SENDKEY=
# Bark：填完整前缀，例如 https://api.day.app/你的Key。
LYNKCO_BARK_URL=
# 通用 Webhook：接收 POST JSON，字段为 title/content/status。
LYNKCO_NOTIFY_WEBHOOK=
LYNKCO_AUTO_TIMEOUT=180

# Windows 脚本使用的 Python 可执行文件，可选。
PYTHON_EXE=python
